   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# ETF Trend Engine — 1편: ETF 리스트 + 데이터 수집 + 50주 이동평균\n",
    "\n",
    "국내 IRP/DC 계좌에서 매수 가능한 국내상장 ETF 기준으로 구성했습니다.\n",
    "yfinance로 주가를 받아와 주간 종가 기준 50주 이동평균(MA50)을 계산하고,\n",
    "현재가가 MA50 위/아래 어디에 있는지 즉시 확인할 수 있습니다.\n",
    "\n",
    "> Colab 상단 메뉴에서 '런타임 > 모두 실행'을 누르면 끝까지 실행됩니다."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 1. 필요한 패키지 설치\n",
    "!pip install -q yfinance pandas\n",
    "\n",
    "import yfinance as yf\n",
    "import pandas as pd\n",
    "from datetime import datetime\n",
    "\n",
    "pd.set_option('display.float_format', lambda x: f'{x:,.2f}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 2. ETF 리스트 정의 (IRP/DC 매수 가능 국내상장 ETF 기준, 필요시 자유롭게 수정하세요)\n",
    "# 형식: '표시이름': 'yfinance 티커 (KRX는 .KS 접미사)'\n",
    "\n",
    "ETF_LIST = {\n",
    "    'S&P500':  '360750.KS',   # TIGER 미국S&P500\n",
    "    'GOLD':    '132030.KS',   # KODEX 골드선물(H)\n",
    "    'INDIA':   '453870.KS',   # TIGER 인도니프티50\n",
    "    'SEMI':    '091160.KS',   # KODEX 반도체\n",
    "    'JAPAN':   '241180.KS',   # TIGER 일본니케이225\n",
    "    'OIL':     '130680.KS',   # TIGER 원유선물Enhanced(H)\n",
    "    'KOSPI200':'069500.KS',   # KODEX 200\n",
    "    'NASDAQ':  '133690.KS',   # TIGER 미국나스닥100\n",
    "    'BOND':    '148070.KS',   # KOSEF 국고채10년\n",
    "}\n",
    "\n",
    "# 위 티커/코드는 예시이며, 실제 보유 계좌에서 매수 가능한 종목코드로 반드시 교체 후 사용하세요.\n",
    "print(f'등록된 ETF 수: {len(ETF_LIST)}개')\n",
    "for name, ticker in ETF_LIST.items():\n",
    "    print(f'  {name:10s} -> {ticker}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 3. 데이터 다운로드 함수 (일봉 -> 주봉 변환)\n",
    "\n",
def download_weekly(ticker, years=5):
    df = yf.download(ticker, period=f'{years}y', interval='1d', progress=False, auto_adjust=True)
    if df.empty:
        return None
    if isinstance(df.columns, pd.MultiIndex):
        close = df['Close'].iloc[:, 0]
    else:
        close = df['Close']
    weekly = close.resample('W-FRI').last().dropna()
    return weekly

def calc_ma50(weekly_close):
    ma50 = weekly_close.rolling(window=50).mean()
    return ma50

   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 4. 전체 ETF 순회하며 데이터 수집 + MA50 계산\n",
    "\n",
    "results = {}\n",
    "\n",
    "for name, ticker in ETF_LIST.items():\n",
    "    try:\n",
    "        weekly = download_weekly(ticker)\n",
    "        if weekly is None or len(weekly) < 50:\n",
    "            print(f'[SKIP] {name} ({ticker}) - 데이터 부족')\n",
    "            continue\n",
    "        ma50 = calc_ma50(weekly)\n",
    "        current_price = weekly.iloc[-1]\n",
    "        current_ma50 = ma50.iloc[-1]\n",
    "        gap_pct = (current_price / current_ma50 - 1) * 100\n",
    "        results[name] = {\n",
    "            'ticker': ticker,\n",
    "            'price': current_price,\n",
    "            'ma50': current_ma50,\n",
    "            'gap_pct': gap_pct,\n",
    "            'above_ma50': current_price > current_ma50,\n",
    "        }\n",
    "    except Exception as e:\n",
    "        print(f'[ERROR] {name} ({ticker}): {e}')\n",
    "\n",
    "print(f'\\n수집 완료: {len(results)}/{len(ETF_LIST)}개')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 5. 결과 요약표\n",
    "\n",
    "rows = []\n",
    "for name, r in results.items():\n",
    "    rows.append({\n",
    "        'ETF': name,\n",
    "        '현재가': round(r['price'], 2),\n",
    "        'MA50': round(r['ma50'], 2),\n",
    "        '이격도(%)': round(r['gap_pct'], 2),\n",
    "        '상태': '\u2705 MA50 위' if r['above_ma50'] else '\u274c MA50 아래',\n",
    "    })\n",
    "\n",
    "summary_df = pd.DataFrame(rows).sort_values('이격도(%)', ascending=False).reset_index(drop=True)\n",
    "\n",
    "print('=' * 40)\n",
    "print('ETF TREND ENGINE — 50주선 현황')\n",
    "print(datetime.now().strftime('%Y-%m-%d'))\n",
    "print('=' * 40)\n",
    "summary_df"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# 6. 다음 모듈(02_점수계산)에서 그대로 이어 쓸 수 있도록 CSV로 저장\n",
    "\n",
    "summary_df.to_csv('etf_ma50_snapshot.csv', index=False, encoding='utf-8-sig')\n",
    "print(\"'etf_ma50_snapshot.csv' 저장 완료 — 다음 노트북(02_점수계산)에서 불러와 사용합니다.\")"
   ]
  }
